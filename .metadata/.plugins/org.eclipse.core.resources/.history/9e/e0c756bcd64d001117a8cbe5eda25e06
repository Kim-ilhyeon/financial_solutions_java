package com.kh.basic;

public class Variable {
		/*
		 * 변수 : 값을 기록하고 사용하기 위한 메모리 공간
		 * 
		 * [표현식]
		 * 자료형 변수명;
		 */
	public static void main(String[] args) {
		// 정수형 변수 num을 선언
		int num;
		
		// 정수형 변수 num에 10이라는 값을 대입
		num = 10;
		
		// 변수 num을 Console창에 출력
		System.out.println(num);
		// sysout + ctrl + space => Enter 자동완성
		
		// 참과 거짓을 표현하는 자료형으로 isTrue라는 이름의 변수를 선언
		boolean isTrue = false;
		isTrue = true;
		
		System.out.println(isTrue);
		
		// 실수형(소수점 6자리까지 출력)으로 num2라는 이름의 변수를 선언
		float num2;
		num2 = 3.14159265353579f;
		
		System.out.println(num2);
		System.out.printf("%.6f", num2);
		System.out.println();
		
		
		// 정수 자료형
		int in = 10;	// 기본값 4바이트
		byte by = 10;	// 1바이트
		short sh = 10;	// 2바이트
		long lo = 10;	// 8바이트
		
		// 실수 자료형
		float fl = 4.24f;	// 4바이트
		double db = 4.24;	// 8바이트
		
		System.out.println(fl);
		System.out.println(db);
		
		// 문자 자료형
		char ch1 = '김';
		char ch2 = '일';
		char ch3 = '현';
		
		// 기본적으로 char자료형은 연산 시 int로 형변환된다.
		System.out.println(ch1 + ch2 + ch3);
		System.out.print(ch1);
		System.out.print(ch2);
		System.out.print(ch3);
		System.out.println();
		
		// 논리 자료형
		boolean b1 = false;
		boolean b2 = 10 > 0;
		boolean b3 = 20 == 10;
		
		System.out.println(b1);
		System.out.println(b2);
		System.out.println(b3);
		
		/*
		 * 원시타입 : 가장 기본적인 데이터 타입, 값 자체를 저장하며 추가적인 속성이 없다.
		 * => boolean, int, float, char ... 등등
		 * 
		 * 문자열
		 * String
		 * 문자열은 할당 메모리크기가 가변적이므로 원시타입이 아닌 객체타입으로 변수를 만든다.
		 * 
		 * 원래 객체를 만드는 방식
		 * String 변수명 = new String(초기값);
		 * 
		 * 문자열은 특별히 자주 사용하기 때문에 원시타입과 동일하게 생성, 사용이 가능함
		 * String 변수명 = "가나다라마바";
		 */
		String str1 = "안녕하세요 김일현입니다.";
		System.out.println(str1);
		String str2 = new String("안녕하세요!!");
		System.out.println(str2);
		
		// 문자열에는 이스케이프 시퀀스가 존재함
		// : 문자열 내에서 탭, 백슬래시, 작은 따옴표 등을 사용하기 위한 방식
		
		// \t : 탭(tab)
		System.out.println("이름\t나이\t주소");
		
		// \\ : 백슬래시(\)
		System.out.println("이름\\나이\\주소");
		
		// \" : 쌍 따옴표(")
		System.out.println("이름\"나이\"주소");
		
		// \n : 개행(Enter)
		System.out.println("이름\n나이\n주소");		
		
		
	}
}



















